[
  {
    "context": "vim_mode == normal",
    "bindings": {
      "space h": "workspace::ActivatePaneLeft",
      "space l": "workspace::ActivatePaneRight",
      "space j": "workspace::ActivatePaneDown",
      "space k": "workspace::ActivatePaneUp",
      "space c a": "editor::ToggleCodeActions",
      "space g r": "editor::FindAllReferences",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "v": "editor::SelectLargerSyntaxNode",
      "V": "editor::SelectSmallerSyntaxNode",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "escape escape": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-/": [
        "editor::ToggleComments",
        {
          "advance_downwards": true,
        },
      ],
    },
  },
]
